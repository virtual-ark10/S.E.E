<%- include('../partials/header', { title: title, extraCSS: '' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3><i class="bi bi-database"></i> <%= config.entityPlural || 'Entities' %></h3>
  <div>
    <a href="/admin/entities/import" class="btn btn-outline-primary me-2"><i class="bi bi-upload me-1"></i> Import CSV</a>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEntityModal"><i class="bi bi-plus-circle me-1"></i> Add</button>
  </div>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-md-3">
        <input type="text" name="search" class="form-control form-control-sm" value="<%= filters.search || '' %>" placeholder="Search...">
      </div>
      <div class="col-md-2">
        <select name="category" class="form-select form-select-sm">
          <option value="">All Categories</option>
          <% allCategories.forEach(cat => { %>
            <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <select name="location" class="form-select form-select-sm">
          <option value="">All Locations</option>
          <% allLocations.forEach(loc => { %>
            <option value="<%= loc %>" <%= filters.location === loc ? 'selected' : '' %>><%= loc %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-1"><button type="submit" class="btn btn-sm btn-primary w-100">Filter</button></div>
      <div class="col-md-1"><a href="/admin/entities" class="btn btn-sm btn-outline-secondary w-100">Clear</a></div>
    </form>
  </div>
</div>

<p class="text-muted small"><%= pagination.total %> total <%= (config.entityPlural || 'entities').toLowerCase() %></p>

<!-- Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (entities.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-database display-4 text-muted"></i>
        <p class="mt-2 text-muted">No <%= (config.entityPlural || 'entities').toLowerCase() %> found</p>
        <a href="/admin/entities/import" class="btn btn-primary btn-sm">Import from CSV</a>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr><th>Name</th><th>Location</th><th>Category</th><th>Rating</th><th>Source</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% entities.forEach(entity => { %>
              <tr>
                <td>
                  <strong><%= entity.name %></strong>
                  <% if (entity.description) { %><div class="small text-muted text-truncate" style="max-width:200px;"><%= entity.description %></div><% } %>
                </td>
                <td><%= entity.location || '-' %></td>
                <td><%= entity.category || (entity.categories && entity.categories[0]) || '-' %></td>
                <td>
                  <% if (entity.rating > 0) { %>
                    <span class="text-warning"><%= Number(entity.rating).toFixed(1) %>★</span>
                    <small class="text-muted">(<%= entity.reviewCount || 0 %>)</small>
                  <% } else { %>-<% } %>
                </td>
                <td><small class="text-muted"><%= entity.source || 'manual' %></small></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary btn-edit-entity" data-id="<%= entity._id %>" title="Edit"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-outline-danger btn-delete-entity" data-id="<%= entity._id %>" title="Delete"><i class="bi bi-trash"></i></button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Pagination -->
<% if (pagination.pages > 1) { %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center">
      <% for (let i = 1; i <= pagination.pages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>&category=<%= filters.category || '' %>&location=<%= filters.location || '' %>&search=<%= filters.search || '' %>"><%= i %></a>
        </li>
      <% } %>
    </ul>
  </nav>
<% } %>

<!-- Add Entity Modal -->
<div class="modal fade" id="addEntityModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add <%= config.entityType || 'Entity' %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="addEntityForm">
          <div class="mb-3"><label class="form-label">Name *</label><input type="text" class="form-control" name="name" required></div>
          <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="2"></textarea></div>
          <div class="row">
            <div class="col-md-6 mb-3"><label class="form-label">Location</label><input type="text" class="form-control" name="location"></div>
            <div class="col-md-6 mb-3"><label class="form-label">Category</label><input type="text" class="form-control" name="category"></div>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3"><label class="form-label">Rating</label><input type="number" class="form-control" name="rating" min="0" max="5" step="0.1"></div>
            <div class="col-md-4 mb-3"><label class="form-label">Reviews</label><input type="number" class="form-control" name="reviewCount" min="0"></div>
            <div class="col-md-4 mb-3"><label class="form-label">Phone</label><input type="text" class="form-control" name="phone"></div>
          </div>
          <div class="mb-3"><label class="form-label">Website</label><input type="url" class="form-control" name="website"></div>
          <div class="mb-3"><label class="form-label">Address</label><input type="text" class="form-control" name="address"></div>
          <div class="mb-3"><label class="form-label">Tags (comma-separated)</label><input type="text" class="form-control" name="tags" placeholder="tag1, tag2"></div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveEntityBtn">Save</button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer', { extraJS: `
<script>
  document.getElementById('saveEntityBtn')?.addEventListener('click', async () => {
    const form = document.getElementById('addEntityForm');
    const data = Object.fromEntries(new FormData(form));
    data.tags = JSON.stringify((data.tags || '').split(',').map(t => t.trim()).filter(Boolean));
    const res = await fetch('/api/entities', {
      method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(data)
    });
    const result = await res.json();
    if (result.success) location.reload();
    else alert(result.message || 'Error creating entity');
  });
  document.querySelectorAll('.btn-delete-entity').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this entity?')) return;
      const res = await fetch('/api/entities/' + btn.dataset.id, { method: 'DELETE' });
      if (res.ok) location.reload();
      else alert('Delete failed');
    });
  });
</script>
` }) %>
