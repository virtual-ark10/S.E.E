<%- include('partials/header', { title: 'Error', extraCSS: '' }) %>
<div class="text-center py-5">
  <div style="font-size: 4rem; color: var(--see-error);">
    <i class="bi bi-exclamation-triangle"></i>
  </div>
  <h2 class="mt-3 mb-2" style="font-weight: 700;">Something Went Wrong</h2>
  <% if (typeof error !== 'undefined' && error.message) { %>
    <div class="alert alert-danger d-inline-block mt-3" style="border-radius: 12px;"><%= error.message %></div>
  <% } %>
  <div class="mt-4">
    <a href="/admin" class="btn btn-primary" style="border-radius: 25px; padding: 0.75rem 2rem; font-weight: 600;">
      <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
  </div>
</div>
<%- include('partials/footer', { extraJS: '' }) %>
